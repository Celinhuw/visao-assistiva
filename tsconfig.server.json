{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "node",
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "outDir": "dist-server",
    "rootDir": "."
  },
  "include": ["server.ts", "endpoints/**/*.ts", "helpers/**/*.ts", "helpers/**/*.tsx"],
  "exclude": ["node_modules", "dist", "**/*.spec.tsx"]
}
