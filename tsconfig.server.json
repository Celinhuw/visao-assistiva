{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "node",
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "jsx": "react-jsx",
    "outDir": "dist-server",
    "rootDir": "."
  },
  "include": ["api/**/*.ts", "endpoints/**/*.ts", "endpoints/**/*.tsx", "helpers/**/*.ts", "helpers/**/*.tsx"],
  "exclude": ["node_modules", "dist", "dist-server", "**/*.spec.tsx"]
}
