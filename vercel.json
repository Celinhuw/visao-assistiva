{
  "version": 2,
  "builds": [
    {
      "src": "api-bundle/index.mjs",
      "use": "@vercel/node"
    },
    {
      "src": "dist/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/_api/(.*)",
      "dest": "/api-bundle/index.mjs"
    },
    {
      "src": "/_assets/(.*)",
      "dest": "/dist/_assets/$1"
    },
    {
      "src": "/(.*\\.(js|css|png|jpg|ico|svg|woff|woff2))",
      "dest": "/dist/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/dist/index.html"
    }
  ]
}
